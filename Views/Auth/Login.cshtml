@using EMS.Dto
@model LoginUserDto
@{
    ViewData["Title"] = "Login";
}

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="row shadow-lg rounded overflow-hidden bg-white" style="max-width: 950px; width: 100%;">

        <div class="col-lg-6 d-none d-lg-flex flex-column justify-content-center bg-primary text-white p-5">
            <h1 class="fw-bold display-5 mb-4">EMS Portal</h1>

            <p class="lead mb-4">
                Manage employees, attendance, departments, and leave workflows efficiently.
            </p>

            <ul class="list-unstyled fs-5">
                <li class="mb-3">✔ Employee Management</li>
                <li class="mb-3">✔ Attendance Tracking</li>
                <li class="mb-3">✔ Leave Management</li>
                <li class="mb-3">✔ Reports & Analytics</li>
            </ul>
        </div>

        <div class="col-lg-6 p-5">
            <div class="text-center mb-5">
                <h2 class="fw-bold">Welcome Back</h2>
                <p class="text-muted">
                    Sign in to continue
                </p>
            </div>
            <p class="text-danger fw-bold text-center">@TempData["Message"]</p>

            <form method="post" asp-action="HandleLogin">

                <div class="mb-4">
                    <label class="form-label fw-semibold">Email Address</label>
                    <input type="email"
                           class="form-control form-control-lg"
                           placeholder="Enter your email" 
                           asp-for="Email"/>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Password</label>
                    <input type="password"
                           class="form-control form-control-lg"
                           placeholder="Enter your password" asp-for="Password"/>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               id="rememberMe" 
                               asp-for="Remember"/>

                        <label class="form-check-label" for="rememberMe">
                            Remember Me
                        </label>
                    </div>

                    <a href="#" class="text-decoration-none">
                        Forgot Password?
                    </a>

                </div>

                <button type="submit"
                        class="btn btn-primary btn-lg w-100 mb-4">
                    Sign In
                </button>

                <div class="text-center text-muted">
                    Need help?
                    <a href="#" class="text-decoration-none fw-semibold">
                        Contact Admin
                    </a>
                </div>

            </form>
        </div>

    </div>
</div>