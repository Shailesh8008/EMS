@{
    ViewData["Title"] = "Home Page";
}

<div class="min-vh-100 bg-light text-dark">
    <section class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h2 class="display-4 fw-bold mb-4">
                    Simplify Workforce Management
                </h2>

                <p class="lead text-muted mb-4">
                    Manage employees, attendance, departments, payroll records,
                    and leave requests from a centralized enterprise platform.
                </p>

                <div class="d-flex gap-3">
                    <button class="btn btn-primary btn-lg px-4">
                        Get Started
                    </button>

                    <button class="btn btn-outline-secondary btn-lg px-4">
                        Learn More
                    </button>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="bg-white rounded shadow p-4 border">
                    <div class="row g-4">
                        <div class="col-6">
                            <div class="bg-light rounded p-4 border">
                                <p class="text-muted mb-2">Total Employees</p>
                                <h3 class="fw-bold">248</h3>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="bg-light rounded p-4 border">
                                <p class="text-muted mb-2">Departments</p>
                                <h3 class="fw-bold">12</h3>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="bg-light rounded p-4 border">
                                <p class="text-muted mb-2">Pending Leaves</p>
                                <h3 class="fw-bold">18</h3>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="bg-light rounded p-4 border">
                                <p class="text-muted mb-2">Attendance Today</p>
                                <h3 class="fw-bold">92%</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Modules Section -->
    <section class="container py-5">
        <div class="text-center mb-5">
            <h3 class="fw-bold display-6">Core Modules</h3>
            <p class="text-muted lead">
                Everything your HR department needs in one system.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Employee Management</h5>
                        <p class="card-text text-muted">
                            Manage employee profiles, departments, and roles.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Attendance Tracking</h5>
                        <p class="card-text text-muted">
                            Track daily attendance and monitor work hours.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Leave Requests</h5>
                        <p class="card-text text-muted">
                            Approve or reject employee leave applications.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Reports & Analytics</h5>
                        <p class="card-text text-muted">
                            View HR insights, attendance trends, and reports.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="container py-5">
        <div class="bg-primary text-white rounded p-5 shadow d-lg-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-bold mb-3">
                    Ready to manage your workforce efficiently?
                </h3>
                <p class="lead mb-0">
                    Start organizing employees, departments, attendance, and leave workflows today.
                </p>
            </div>

            <button class="btn btn-light btn-lg mt-4 mt-lg-0 px-4">
                Explore Dashboard
            </button>
        </div>
    </section>
</div>
