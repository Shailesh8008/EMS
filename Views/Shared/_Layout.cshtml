<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EMS</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EMS.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="bg-white shadow-sm border-bottom">
        <div class="container py-3 d-flex justify-content-between align-items-center">
            <a href="/" class="text-decoration-none text-dark">
                <h1 class="h3 fw-bold mb-0">EMS Portal</h1>
                <small class="text-muted">Enterprise Employee Management System</small>
            </a>

            @if (ViewData["Title"]?.ToString() != "Login")
            {
                <nav class="d-none d-md-flex gap-4 fw-medium">
                    <a href="#" class="text-decoration-none text-dark">Dashboard</a>
                    <a href="#" class="text-decoration-none text-dark">Employees</a>
                    <a href="#" class="text-decoration-none text-dark">Attendance</a>
                    <a href="#" class="text-decoration-none text-dark">Leave Requests</a>
                </nav>
            }
            
        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-white border-top mt-5">
        <div class="container py-4 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <p class="text-muted mb-0">
                © @DateTime.UtcNow.Year EMS Portal. All rights reserved.
            </p>

            <div class="d-flex gap-4">
                <a href="#" class="text-decoration-none text-muted">Privacy Policy</a>
                <a href="#" class="text-decoration-none text-muted">Terms</a>
                <a href="#" class="text-decoration-none text-muted">Support</a>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
